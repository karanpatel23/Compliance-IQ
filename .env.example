# Required
SESSION_SECRET=replace-with-long-random-string
APP_ENCRYPTION_KEY=replace-with-long-random-secret

# Database (Render Postgres recommended for production)
# Example: postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./compliance_iq.db

# Optional ops settings
BACKUP_SOURCE_FILE=./compliance_iq.db
BACKUP_DIR=./backups
